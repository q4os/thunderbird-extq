#***q4os*setup*config*header*do*not*delete*it***#

TEMPLATES_DIR_0="$TEMPLATESDIR0"
TEMPLATES_DIR="setup_templates"
OUT_DIR="../setup_out"

#CHKINSTALL_COMMAND="cp -r filesystem/* /"
CHKINSTALL_COMMAND="echo"
INSTALL_PREFIX="/"
SETUP_TYPE="2"
Q4VER_MIN="1.0"
# Q4VER_MAX="2.9999"
CHK_INET="1"
# PREPACK_SH="1"
LANGUAGE_PACKAGE="thunderbird-l10n--xxlangcodexx-, lightning-l10n--xxlangcodexx-, hunspell--xxlangcodexx-"
PK_NAME="thunderbird-q4"
APPNAME_DESC="Mozilla Thunderbird"
PK_VERS="1.11"
PK_RELEASE="a1"

PK_DEPENDS="libc6, q4os-desktop \(\>= 1.0\), desktop-file-utils, gtk2-engines, thunderbird"
#'desktop-file-utils' needed for 'open containing folder' and mime associations
# todo: deactivate lightning on the first start

PK_RECOMMENDS="lightning"
# PK_CONFLICTS="icedove"
PK_MAINTAINER="q4osteam@q4os.org"

APPLNK_ENTRY="0"
# DESKTOP_ENTRY="0"
# MENU_ENTRY="0"
# REG_ENTRY="0"
# UNINSTALL_ENTRY="0"

APP_ICON="thunderbird"
APP_LINK="thunderbird"

UNINST_ADPCKS="thunderbird"
INCLUDE_DEBS="0"
PK_ARCH="all"
